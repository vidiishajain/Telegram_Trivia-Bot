# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# NEVER commit your real `.env` — it holds secrets. It is already gitignored.

# --- Required ---------------------------------------------------------------

# Your OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# --- Options (sensible defaults) --------------------------------------------

# Which model each tier ("fast", "balanced", "smart", ...) maps to is set in
# code, in src/agent/services/llm.py — not here. Pick a model in code with
# build_model("smart"); no env var needed.

# Logging verbosity: DEBUG, INFO, WARNING, or ERROR.
LOG_LEVEL=INFO

# Password for deployed web apps. Leave unset locally; SET IT before you deploy a
# web demo publicly, so it's behind a login.
# APP_PASSWORD=change-me

# --- Media: fal.ai (only if you generate images/video/audio) ----------------

# Get a key at https://fal.ai/dashboard/keys
# FAL_KEY=...

# --- Storage: Cloudflare R2 (only if you store files) -----------------------
# All four are needed together. From your Cloudflare R2 dashboard.
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=...
# If the bucket is shared, your instructor gives you a prefix that scopes your
# slice of it. The storage service adds/strips it automatically.
# R2_PREFIX=student07
# Public/custom domain on the bucket — lets storage.public_url() build stable
# links (no expiry) that you can save in the DB and render later.
# R2_PUBLIC_BASE_URL=https://files.example.com

# --- Database: Neon Postgres (only if you use a database) -------------------

# Neon connection string. Use the "pooled" connection URL.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
